# vibe-x-agent runtime env. Copy to .env and fill in:
#   cp .env.example .env ; $EDITOR .env
# On the VPS the systemd units read this via EnvironmentFile=.
# Load it into a shell with:  set -a; source .env; set +a

# --- Required: X (Twitter) API, OAuth 1.0a user context ---
# From the X developer portal (docs/01-X_API_SETUP.md). One App can post
# as many accounts; the consumer key/secret identify the App.
TWITTER_API_KEY=
TWITTER_API_SECRET=
# Per-account tokens. Leave blank and mint them with the PIN flow:
#   python -m x_agent.authorize begin --label myproduct
#   python -m x_agent.authorize finish <PIN> --label myproduct --primary
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- Safety switch ---
# true (default) = never actually posts; writes would-be posts to
# state/dry_runs/ instead. Flip to false only after reviewing the dry runs.
TWITTER_BOT_DRY_RUN=true

# --- Optional: app-only bearer token ---
# Not required: the feedback loop reads metrics with the OAuth tokens
# above. A bearer additionally unlocks pulling replies on viral posts.
# TWITTER_BEARER_TOKEN=

# --- Claude CLI auth (plan auth recommended) ---
# The agent shells out to `claude -p` for copy, billing against your
# Claude Pro/Max plan via ~/.claude/.credentials.json (run `claude` once
# and /login on the VPS). NO API KEY NEEDED in this mode. Without it the
# agent still posts, using deterministic templates. Only set
# ANTHROPIC_API_KEY if you specifically want per-token billing.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: cadence / caps ---
# X_AGENT_MAX_POSTS_PER_DAY=4
# X_AGENT_MIN_HOURS_BETWEEN_POSTS=3
# X_AGENT_MAX_POSTS_PER_RUN=1
# X_AGENT_LINK_POLICY=sometimes      # always | sometimes | never
# X_AGENT_LINK_EVERY_N=3
# X_AGENT_LLM_MODEL=sonnet

# --- Optional: visual content types (meme / comic images) ---
# Enable the meme/comic angles in product_config.py; these style the images.
# X_AGENT_BRAND_COLOR=#1d9bf0      # title bar + accents on rendered images
# X_AGENT_HANDLE=@yourhandle       # printed on the comic footer (cosmetic)

# --- Optional: the feedback loop / bandit ---
# X_AGENT_EXPLORATION_FLOOR=0.15     # min fraction chosen at random (coverage)
# X_AGENT_REWARD_SETTLE_DAYS=3       # post age at which its reward is credited
# X_AGENT_REWARD_SCALE=10            # higher = more engagement needed per reward unit
# X_AGENT_SLOP_THRESHOLD=45          # AI-slop gate, of 50

# --- Optional: web grounding (freshness) ---
# Off by default. When on, the first generation attempt per post lets Claude
# use read-only web search to find one timely, real hook and tie the product
# to it (instead of only your static talking points). Requires the claude CLI
# to be logged in on this host. Falls back to normal generation on any failure.
# X_AGENT_WEB_GROUNDING=false
# X_AGENT_WEB_GROUNDING_BUDGET_USD=0.50   # per-post spend cap for the grounded call
# X_AGENT_WEB_GROUNDING_TIMEOUT_S=240     # grounded calls are slower (they search)
